{
  "name": "@illamhelp/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "description": "IllamHelp mobile app (React Native + Expo)",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "e2e:maestro:init": "bash ./scripts/maestro-native-init.sh",
    "e2e:maestro:check": "bash ./scripts/maestro-check.sh",
    "e2e:maestro:build:ios": "bash ./scripts/maestro-build-ios.sh",
    "e2e:maestro:test:ios": "bash ./scripts/maestro-test-ios.sh",
    "e2e:maestro:test:ios:debug": "MAESTRO_VERBOSE=true bash ./scripts/maestro-test-ios.sh",
    "e2e:maestro:ios": "pnpm run e2e:maestro:test:ios",
    "e2e:maestro:build:android": "bash ./scripts/maestro-build-android.sh",
    "e2e:maestro:test:android": "bash ./scripts/maestro-test-android.sh",
    "e2e:maestro:test:android:debug": "MAESTRO_VERBOSE=true bash ./scripts/maestro-test-android.sh",
    "e2e:maestro:android": "pnpm run e2e:maestro:test:android",
    "e2e:maestro": "pnpm run e2e:maestro:ios && pnpm run e2e:maestro:android",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No mobile tests yet\"",
    "build": "echo \"Use EAS or native builds when ready\""
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@expo/metro-runtime": "~4.0.1",
    "@illamhelp/shared-types": "workspace:*",
    "@illamhelp/ui-tokens": "workspace:*",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "52.0.49",
    "expo-asset": "~11.0.5",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "babel-preset-expo": "~12.0.12",
    "eslint": "^9.20.0",
    "expo-modules-autolinking": "2.0.8",
    "globals": "^15.14.0",
    "typescript": "^5.8.2"
  }
}

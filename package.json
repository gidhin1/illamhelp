{
  "name": "illamhelp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev:api": "mvn -f api-java/pom.xml spring-boot:run",
    "dev:web": "corepack pnpm --filter @illamhelp/web dev",
    "dev:admin": "corepack pnpm --filter @illamhelp/admin dev",
    "dev:mobile": "corepack pnpm --filter @illamhelp/mobile start",
    "build": "mvn -f api-java/pom.xml package && corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "mvn -f api-java/pom.xml test && corepack pnpm -r test",
    "test:ui:web": "bash ./scripts/run-with-e2e-admin-env.sh bash ./scripts/run-playwright-suite.sh tests/playwright/playwright.web.config.ts",
    "test:ui:admin": "bash ./scripts/run-with-e2e-admin-env.sh bash ./scripts/run-playwright-suite.sh tests/playwright/playwright.admin.config.ts",
    "test:ui:mobile": "corepack pnpm --filter @illamhelp/mobile e2e:maestro",
    "test:ui:mobile:ios": "corepack pnpm --filter @illamhelp/mobile e2e:maestro:ios",
    "test:ui:mobile:android": "corepack pnpm --filter @illamhelp/mobile e2e:maestro:android",
    "test:ui": "corepack pnpm run test:ui:web && corepack pnpm run test:ui:admin && corepack pnpm run test:ui:mobile",
    "test:ui:install": "playwright install chromium",
    "infra:up": "docker compose --project-name illamhelp --env-file .env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --project-name illamhelp --env-file .env -f infra/docker-compose.yml down -v --remove-orphans"
  },
  "pnpm": {
    "overrides": {
      "@expo/cli>minimatch": "3.1.4",
      "@expo/fingerprint>minimatch": "3.1.4",
      "@expo/metro-config>minimatch": "3.1.4",
      "minimatch@3.1.2": "3.1.4",
      "glob@6>minimatch": "3.1.4",
      "glob@7>minimatch": "3.1.4",
      "glob@10>minimatch": "9.0.7",
      "glob@11>minimatch": "10.2.3",
      "glob@13>minimatch": "10.2.3",
      "@expo/cli>tar": "7.5.11",
      "cacache>tar": "7.5.11",
      "@expo/cli>undici": "6.24.0"
    },
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "dtrace-provider",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}

# Runtime secrets must be provided locally. Do not commit credentials.

# App
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
STRICT_ORIGIN_CHECK=true
TRUST_PROXY=false
BODY_LIMIT_BYTES=1048576
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
ENABLE_HSTS=false
PROFILE_PII_ENCRYPTION_KEY=abcdefgh12345678ijkl

# PostgreSQL
POSTGRES_DB=illamhelp
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=ap-south-1
MINIO_BUCKET_QUARANTINE=illamhelp-quarantine
MINIO_BUCKET_APPROVED=illamhelp-approved
MINIO_BUCKET_PRIVATE=illamhelp-private

# Keycloak
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=illamhelp
KEYCLOAK_CLIENT_ID=illamhelp-api
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_HTTP_TIMEOUT_MS=8000

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_JAVA_OPTS="-Xms384m -Xmx384m"

# NATS
NATS_URL=nats://localhost:4222

# OPA
OPA_URL=http://localhost:8181

# Platform override for images without ARM64 manifests (macOS Apple Silicon)
CLAMAV_PLATFORM=linux/amd64

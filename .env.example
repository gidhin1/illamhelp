# Runtime secrets must be provided locally. Do not commit credentials.

# App
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002,http://localhost:3003,http://127.0.0.1:3003
STRICT_ORIGIN_CHECK=true
TRUSTED_PROXY_CIDRS=
BODY_LIMIT_BYTES=1048576
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
JOBS_WRITE_RATE_LIMIT_WINDOW_MS=60000
JOBS_WRITE_RATE_LIMIT_MAX=30
CONNECTIONS_WRITE_RATE_LIMIT_WINDOW_MS=60000
CONNECTIONS_WRITE_RATE_LIMIT_MAX=30
CONSENT_WRITE_RATE_LIMIT_WINDOW_MS=60000
CONSENT_WRITE_RATE_LIMIT_MAX=30
MEDIA_WRITE_RATE_LIMIT_WINDOW_MS=60000
MEDIA_WRITE_RATE_LIMIT_MAX=20
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX=120
ENABLE_HSTS=false
PROFILE_PII_ENCRYPTION_KEY=

# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Redis
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
REDIS_RATE_LIMIT_ENABLED=true
REDIS_CONNECT_TIMEOUT_MS=500
REDIS_COMMAND_TIMEOUT_MS=500

# MinIO
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=ap-south-1
MINIO_BUCKET_QUARANTINE=illamhelp-quarantine
MINIO_BUCKET_APPROVED=illamhelp-approved
MINIO_BUCKET_PRIVATE=illamhelp-private
MEDIA_MODERATION_WORKER_ENABLED=true
MEDIA_MODERATION_WORKER_BATCH_SIZE=10
MEDIA_MODERATION_WORKER_DELAY_MS=5000

# Keycloak
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=illamhelp
KEYCLOAK_CLIENT_ID=illamhelp-api
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_HTTP_TIMEOUT_MS=8000
E2E_ADMIN_USERNAME=
E2E_ADMIN_PASSWORD=

# OpenSearch
OPENSEARCH_ENABLED=true
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_JOBS=jobs
OPENSEARCH_TIMEOUT_MS=750
OPENSEARCH_JAVA_OPTS="-Xms384m -Xmx384m"
OPENSEARCH_INITIAL_ADMIN_PASSWORD=
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=

# NATS
NATS_USER=
NATS_PASSWORD=
NATS_URL=nats://${NATS_USER}:${NATS_PASSWORD}@localhost:4222

# OPA
OPA_URL=http://localhost:8181

# Platform override for images without ARM64 manifests (macOS Apple Silicon)
CLAMAV_PLATFORM=linux/amd64

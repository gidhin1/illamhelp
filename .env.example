# Runtime secrets must be provided locally. Do not commit credentials.

# App
NODE_ENV=development
PORT=4000
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# PostgreSQL
POSTGRES_DB=illamhelp
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=ap-south-1
MINIO_BUCKET_QUARANTINE=illamhelp-quarantine
MINIO_BUCKET_APPROVED=illamhelp-approved
MINIO_BUCKET_PRIVATE=illamhelp-private

# Keycloak
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=illamhelp
KEYCLOAK_CLIENT_ID=illamhelp-api
KEYCLOAK_CLIENT_SECRET=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_JAVA_OPTS=-Xms384m -Xmx384m

# NATS
NATS_URL=nats://localhost:4222

# OPA
OPA_URL=http://localhost:8181

# Platform override for images without ARM64 manifests (macOS Apple Silicon)
CLAMAV_PLATFORM=linux/amd64

